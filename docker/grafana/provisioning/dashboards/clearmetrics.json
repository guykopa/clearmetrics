{
  "title": "clearmetrics — API Monitor",
  "uid": "clearmetrics-main",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Request Duration p50 / p95 / p99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(http_requests_total)", "legendFormat": "Total" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m]))", "legendFormat": "5xx/s" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.01 }] }
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Requests by Endpoint",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 4 },
      "targets": [
        { "expr": "sum by (handler) (http_requests_total)", "legendFormat": "{{handler}}" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "options": { "orientation": "horizontal" },
      "datasource": "Prometheus"
    }
  ]
}
